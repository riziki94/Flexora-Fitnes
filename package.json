{
  "name": "team-site-template",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "bun run serve.ts",
    "publish": "bash ./publish.sh",
    "go-live": "bash ./go-live.sh",
    "format": "prettier --write .",
    "build:cap": "bun run build && bun run scripts/generate-capacitor-html.js && bunx cap sync",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "open:ios": "bunx cap open ios",
    "open:android": "bunx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "@neondatabase/serverless": "^1.1.0",
    "@supabase/supabase-js": "^2.110.7",
    "@tanstack/react-router": "^1.158.1",
    "@tanstack/react-start": "^1.158.3",
    "@types/leaflet": "^1.9.21",
    "@types/three": "^0.185.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "pg": "^8.22.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "sharp": "^0.35.3",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.0.5"
  }
}
